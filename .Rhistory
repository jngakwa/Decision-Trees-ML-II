library(tidyverse)
library(e1071)
library(palmerpenguins)
peng <-  penguins %>% drop_na %>%
select(-c(island,year,sex)) %>%
filter(species!='Chinstrap') %>%
droplevels() %>%
filter(abs(flipper_length_mm -210) < 10) %>%
filter(abs(bill_length_mm-42)<3)
peng[,2:5] <- scale(peng[,2:5])
p <- ggplot(peng, aes(x=bill_length_mm, y=flipper_length_mm, color=species))
p + geom_point(size=3) +theme(text=element_text(size=12))
svmpeng <- svm(species ~ . , data = peng, kernel = "linear", cost = 30, scale = FALSE)
plot(svmpeng, peng, body_mass_g ~ bill_depth_mm)
w <- t(svmpeng$coefs) %*% svmpeng$SV
w
# pick the x and y coefficients
bx = w[2] # bill depth
by = w[4] # body mass
b0 = svmpeng$rho # equivalent to beta_0 in e1071 implementation
# plot
base = ggplot(data=peng, mapping= aes(x = bill_depth_mm, y = body_mass_g))
base + geom_point(aes(color=species)) +
geom_abline(slope=-bx/by, intercept=b0/by, color='black') +
geom_abline(slope=-bx/by, intercept=(b0+1)/by, color='gray') +
geom_abline(slope=-bx/by, intercept=(b0-1)/by, color='gray') +
geom_point(data=data.frame(svmpeng$SV), mapping = aes(x = bill_depth_mm, y = body_mass_g), shape=4, size=5)
set.seed(1)
x <- matrix(rnorm(20 * 2), ncol = 2)
y <- c(rep(-1, 10), rep(1, 10))
x[y == 1, ] <- x[y == 1, ] + 1
plot(x, col = (3 - y))
dat <- data.frame(x = x, y = as.factor(y))
svmfit <- svm(y ~ ., data = dat, kernel = "linear",
cost = 10, scale = FALSE)
plot(svmfit, dat)
svmfit$index
summary(svmfit)
svmfit <- svm(y ~ ., data = dat, kernel = "linear",
cost = 0.1, scale = FALSE)
plot(svmfit, dat)
svmfit$index
set.seed(1)
tune.out <- tune(svm, y ~ ., data = dat, kernel = "linear",
ranges = list(cost = c(0.001, 0.01, 0.1, 1, 5, 10, 100)))
set.seed(1)
tune.out <- tune(svm, y ~ ., data = dat, kernel = "linear",
ranges = list(cost = c(0.001, 0.01, 0.1, 1, 5, 10, 100)))
summary(tune.out)
bestmod <- tune.out$best.model
summary(bestmod)
xtest <- matrix(rnorm(20 * 2), ncol = 2)
ytest <- sample(c(-1, 1), 20, rep = TRUE)
xtest[ytest == 1, ] <- xtest[ytest == 1, ] + 1
testdat <- data.frame(x = xtest, y = as.factor(ytest))
ypred <- predict(bestmod, testdat)
table(predict = ypred, truth = testdat$y)
svmfit <- svm(y ~ ., data = dat, kernel = "linear",
cost = .01, scale = FALSE)
ypred <- predict(svmfit, testdat)
table(predict = ypred, truth = testdat$y)
x[y == 1, ] <- x[y == 1, ] + 0.5
plot(x, col = (y + 5) / 2, pch = 19)
x[y == 1, ] <- x[y == 1, ] + 0.5
plot(x, col = (y + 5) / 2, pch = 19)
dat <- data.frame(x = x, y = as.factor(y))
svmfit <- svm(y ~ ., data = dat, kernel = "linear",
cost = 1e5)
summary(svmfit)
plot(svmfit, dat)
svmfit <- svm(y ~ ., data = dat, kernel = "linear", cost = 1)
summary(svmfit)
plot(svmfit, dat)
